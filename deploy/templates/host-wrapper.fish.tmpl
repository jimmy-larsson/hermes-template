# hermes — access %%USER_ID%%'s Hermes AI assistant
#
# Generated by setup.sh — copy to ~/.config/fish/conf.d/hermes.fish
#
# Usage:
#   hermes            — attach to the AI assistant (tmux + Claude Code)
#   hermes <name>     — open/switch to a named Claude Code session
#   hermes shell      — drop into a plain bash shell inside the container
#   hermes list       — show all active Claude Code windows
#
# Configuration:
#   HERMES_CONTAINER — Docker container name
#   HERMES_USER      — Container user to exec as
#   HERMES_REMOTE    — SSH target for remote access (empty = local Docker)
#   HERMES_SSH_PORT  — SSH port (empty = default 22)
#   HERMES_SSH_KEY   — SSH key path (empty = default)

set -gx HERMES_CONTAINER "%%USER_ID%%-hermes"
set -gx HERMES_USER "hermes_%%USER_ID%%"
set -gx HERMES_REMOTE ""           # e.g., "jimmy@vps.example.com"
set -gx HERMES_SSH_PORT ""         # e.g., "2222"
set -gx HERMES_SSH_KEY ""          # e.g., "~/.ssh/id_ed25519"

function __hermes_exec
    set -l flags $argv[1]
    set -e argv[1]
    if test -n "$HERMES_REMOTE"
        set -l ssh_opts -t
        test -n "$HERMES_SSH_PORT"; and set -a ssh_opts -p $HERMES_SSH_PORT
        test -n "$HERMES_SSH_KEY"; and set -a ssh_opts -i $HERMES_SSH_KEY
        ssh $ssh_opts $HERMES_REMOTE docker exec -u $HERMES_USER $flags $HERMES_CONTAINER $argv
    else
        docker exec -u $HERMES_USER $flags $HERMES_CONTAINER $argv
    end
end

function hermes
    set -l cmd $argv[1]

    switch "$cmd"
        case shell
            __hermes_exec -it bash -l
        case list
            __hermes_exec -i tmux list-windows -t hermes -F '  #{window_index}: #{window_name}' 2>/dev/null
            or echo 'No Hermes session running.'
        case ''
            __hermes_exec -it tmux attach -t hermes 2>/dev/null
            or __hermes_exec -it bash -lc hermes
        case '*'
            __hermes_exec -it bash -lc "hermes $cmd"
    end
end
