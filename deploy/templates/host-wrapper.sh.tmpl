# hermes — access %%USER_ID%%'s Hermes AI assistant
#
# Generated by setup.sh — source this in your shell config:
#   echo 'source /path/to/this/file' >> ~/.bashrc
#
# Usage:
#   hermes            — attach to the AI assistant (tmux + Claude Code)
#   hermes <name>     — open/switch to a named Claude Code session
#   hermes shell      — drop into a plain bash shell inside the container
#   hermes list       — show all active Claude Code windows
#
# Configuration:
#   CONTAINER   — Docker container name (set by setup.sh)
#   REMOTE      — SSH target for remote access (empty = local Docker)
#   SSH_PORT    — SSH port (empty = default 22)
#   SSH_KEY     — SSH key path (empty = default)

# ── Config (edit these for standalone/remote use) ──────────────────────────
HERMES_CONTAINER="%%USER_ID%%-hermes"
HERMES_REMOTE=""           # e.g., "jimmy@vps.example.com"
HERMES_SSH_PORT=""         # e.g., "2222"
HERMES_SSH_KEY=""          # e.g., "~/.ssh/id_ed25519"

# ── Internal: run a command inside the container ──────────────────────────
__hermes_exec() {
    local flags="$1"
    shift
    if [ -n "$HERMES_REMOTE" ]; then
        local ssh_opts="-t"
        [ -n "$HERMES_SSH_PORT" ] && ssh_opts="$ssh_opts -p $HERMES_SSH_PORT"
        [ -n "$HERMES_SSH_KEY" ] && ssh_opts="$ssh_opts -i $HERMES_SSH_KEY"
        ssh $ssh_opts "$HERMES_REMOTE" docker exec $flags "$HERMES_CONTAINER" "$@"
    else
        docker exec $flags "$HERMES_CONTAINER" "$@"
    fi
}

# ── Main function ─────────────────────────────────────────────────────────
hermes() {
    local win_name="$1"

    case "$win_name" in
        shell)
            __hermes_exec "-it" bash -l
            ;;
        list)
            __hermes_exec "-i" tmux list-windows -t hermes -F '  #{window_index}: #{window_name}' 2>/dev/null \
                || echo 'No Hermes session running.'
            ;;
        "")
            __hermes_exec "-it" tmux attach -t hermes 2>/dev/null \
                || __hermes_exec "-it" bash -lc "hermes"
            ;;
        *)
            __hermes_exec "-it" bash -lc "hermes $win_name"
            ;;
    esac
}
