# hermes [name] — attach to %%USER_ID%%'s Claude Code sessions
# Generated by setup.sh — source this in your shell config.
hermes() {
    local win_name="$1"

    if [ -n "$win_name" ]; then
        docker exec -it "%%USER_ID%%-hermes" bash -lc "hermes $win_name"
    else
        docker exec -it "%%USER_ID%%-hermes" tmux attach -t hermes
    fi
}
